// WhatsApp Order Management Bot — Prisma Schema
//
// v1 (single-vendor): Physical, digital, hybrid goods. Kobo pricing. Working hours.
// v2 (multi-tenant):  Multiple vendors. VendorCustomer relations. Onboarding sessions.
//                     Notification numbers. Subscription tiers. Bot intelligence.
//
// Migration strategy: v1 fields kept intact for backward-compat. v2 fields added alongside.
// Phase 9 data migration will backfill ownerPhone/storeCode and clean up v1 fields.
//
// Rules:
//   - Monetary values stored in KOBO (integer). Display in ₦ at the app layer.
//   - Phone numbers in international format: +2348012345678

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Vendor ──────────────────────────────────────────────────────────────────

model Vendor {
  id             String     @id @default(uuid())
  businessName   String
  whatsappNumber String     @unique  // v1: primary identifier. v2 superseded by ownerPhone.
  phoneNumber    String
  vendorType     VendorType @default(PHYSICAL_GOODS)
  // API key stored as bcrypt hash — never plaintext
  apiKeyHash     String
  isActive       Boolean    @default(true)
  isVerified     Boolean    @default(false)

  // ── Working hours ────────────────────────────────────────────────────────
  workingHoursStart    String?  @default("08:00")
  workingHoursEnd      String?  @default("21:00")
  workingDays          String?  @default("1,2,3,4,5,6")
  timezone             String?  @default("Africa/Lagos")
  acceptOffHoursOrders Boolean  @default(false)

  // ── v2: Multi-tenant identity ─────────────────────────────────────────
  storeCode    String?  @unique   // short code for store deep-link: wa.me/PING?text=STORECODE
  ownerPhone   String?  @unique   // WhatsApp number used to manage the store (vendor side)
  ownerName    String?
  businessType String   @default("general") // food | fashion | beauty | digital | general
  description  String?            // shown on customer welcome screen
  welcomeMessage String?          // custom greeting override
  isPaused     Boolean  @default(false)     // vendor can pause/resume store

  // ── v2: Payment ───────────────────────────────────────────────────────
  paystackSecretKey  String?  // AES-256-GCM encrypted at rest
  bankName           String?
  bankAccountNumber  String?  // AES-256-GCM encrypted at rest
  bankAccountName    String?
  acceptedPayments   String   @default("both") // paystack | bank | both

  // ── v2: Bot intelligence ──────────────────────────────────────────────
  businessContext     String?  // free-text vendor feeds the bot ("we use halal meat only")
  faqs                String?  // JSON array: [{question, answer}]
  specialInstructions String?  // e.g. "No deliveries after 9pm"

  // ── v2: Subscription ─────────────────────────────────────────────────
  plan               String    @default("free") // free | starter | growth | pro
  subscriptionEndsAt DateTime?

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // ── Relations ─────────────────────────────────────────────────────────
  products             Product[]
  orders               Order[]
  sessions             ConversationSession[]
  offHoursContacts     OffHoursContact[]
  // v2 relations:
  customers            VendorCustomer[]
  notificationNumbers  VendorNotificationNumber[]
  setupSession         VendorSetupSession?

  @@map("vendors")
}

// ─── OffHoursContact ─────────────────────────────────────────────────────────
// Records each customer who messaged while the store was closed.
// Used by the opening-time notification job to send "we're open now!" messages.

model OffHoursContact {
  id            String   @id @default(uuid())
  vendorId      String
  customerPhone String
  contactedAt   DateTime @default(now())
  // Flipped to true once the opening notification has been sent
  notifiedOpen  Boolean  @default(false)

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, notifiedOpen])
  @@index([vendorId, contactedAt])
  @@map("off_hours_contacts")
}

// ─── Product ─────────────────────────────────────────────────────────────────
// Unified product model for both physical and digital items.
// Digital-only fields are nullable and ignored for physical products.

model Product {
  id          String      @id @default(uuid())
  vendorId    String
  name        String
  description String?
  // Price in kobo (e.g. ₦15,000 = 1500000)
  price       Int
  category    String      @default("General")
  productType ProductType @default(PHYSICAL)
  imageUrl    String?
  isAvailable Boolean     @default(true)
  sortOrder   Int         @default(0)  // v2: display order on menu

  // ── Physical product fields ──────────────────────────────────────────────
  // null = unlimited stock; 0 = out of stock
  stockCount  Int?

  // ── Digital product fields ───────────────────────────────────────────────
  // How the product is delivered: a URL link or a Cloudinary-hosted file
  deliveryType    DeliveryType? // LINK or FILE — null for physical products
  // The actual URL/link to send the customer (Cloudinary URL or external link)
  deliveryContent String?
  // Custom message sent to customer along with the link, e.g. "Welcome aboard!"
  deliveryMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor     Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([vendorId])
  @@index([vendorId, isAvailable])
  @@index([vendorId, productType])
  @@map("products")
}

// ─── Customer ────────────────────────────────────────────────────────────────

model Customer {
  id             String   @id @default(uuid())
  whatsappNumber String   @unique  // v1 identifier. v2 uses phone (same value, backfilled in Phase 9).
  name           String?
  language       String   @default("en")
  languageSet    Boolean  @default(false)
  reorderOptOut  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // v2: phone is the global identifier across all vendor stores
  phone String? @unique

  orders          Order[]
  sessions        ConversationSession[]
  vendorRelations VendorCustomer[]       // per-vendor relationship data

  @@map("customers")
}

// ─── Order ───────────────────────────────────────────────────────────────────
// orderType determines the status flow and delivery logic.
// deliveryAddress is only set for PHYSICAL orders.

model Order {
  id                String      @id @default(uuid())
  vendorId          String
  customerId        String
  orderType         OrderType   @default(PHYSICAL)
  status            OrderStatus @default(PENDING_PAYMENT)
  // Total amount in kobo
  totalAmount       Int
  // Physical orders only — null for digital
  deliveryAddress   String?
  notes             String?
  // Unique Paystack reference — used for idempotent webhook processing
  paystackReference String      @unique
  // Set to true after first successful payment webhook to prevent double-processing
  paymentProcessed  Boolean     @default(false)
  // For digital orders: track whether automatic delivery succeeded
  digitalDelivered  Boolean     @default(false)
  // Timestamp when order was physically delivered — used to schedule re-order nudges
  deliveredAt       DateTime?
  // Timestamp when a re-order nudge was sent — prevents duplicate nudges
  reorderSentAt     DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  vendor     Vendor      @relation(fields: [vendorId], references: [id])
  customer   Customer    @relation(fields: [customerId], references: [id])
  orderItems OrderItem[]

  @@index([vendorId])
  @@index([customerId])
  @@index([status])
  @@index([orderType])
  @@index([paystackReference])
  @@map("orders")
}

// ─── OrderItem ───────────────────────────────────────────────────────────────
// unitPrice snapshots the price at order time so historical amounts are stable.

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  // Price in kobo at the moment the order was placed
  unitPrice Int
  notes     String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ─── ConversationSession ─────────────────────────────────────────────────────
// Tracks each customer's position in the conversation state machine.
// One session per customer per vendor — upserted on each message.

model ConversationSession {
  id             String            @id @default(uuid())
  whatsappNumber String
  vendorId       String
  state          ConversationState @default(IDLE)
  // JSON blob: { cart, pendingProductId, deliveryAddress, activeOrderType, ... }
  sessionData    Json              @default("{}")
  expiresAt      DateTime
  updatedAt      DateTime          @updatedAt
  lastMessageId  String?

  // v2: customer FK by id (used by new router; no Prisma relation declared to avoid naming conflict)
  customerId     String?

  vendor   Vendor   @relation(fields: [vendorId], references: [id])
  customer Customer @relation(fields: [whatsappNumber], references: [whatsappNumber])

  // One active session per customer per vendor
  @@unique([whatsappNumber, vendorId])
  @@index([whatsappNumber])
  @@index([expiresAt])
  @@map("conversation_sessions")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum VendorType {
  PHYSICAL_GOODS
  DIGITAL_PRODUCTS
  HYBRID
}

enum ProductType {
  PHYSICAL
  DIGITAL
}

enum DeliveryType {
  LINK  // External URL or platform link (e.g. Google Drive, YouTube, Selar)
  FILE  // Cloudinary-hosted file URL
}

enum OrderType {
  PHYSICAL
  DIGITAL
}

enum OrderStatus {
  PENDING_PAYMENT   // v1: Order created, awaiting payment
  PAYMENT_CONFIRMED // v1: Paystack confirmed payment
  CONFIRMED         // Vendor confirmed the order (physical only)
  PREPARING         // Vendor is preparing the order (physical only)
  READY             // v1: Order ready for pickup/delivery
  OUT_FOR_DELIVERY  // v2: Order is on the way to the customer
  DELIVERED         // Physical order delivered
  DIGITAL_SENT      // Digital product delivered to customer
  CANCELLED         // Order cancelled (by vendor or system)
}

enum ConversationState {
  LANGUAGE_SELECTION // Brand-new customer choosing their preferred language
  IDLE               // No active conversation
  BROWSING           // Viewing catalog
  ORDERING           // Adding items to cart (physical) or viewing product detail (digital)
  AWAITING_ITEM_NOTE // Waiting for special instructions after item added to cart
  AWAITING_ADDRESS   // Waiting for delivery address (physical only)
  AWAITING_PAYMENT   // Payment link sent, waiting for Paystack webhook
  COMPLETED          // Order placed and confirmed — ready for fresh start
}

// ─── v2: VendorCustomer ───────────────────────────────────────────────────────
// Per-vendor relationship data for each customer. Tracks repeat orders,
// opt-outs, and vendor-specific notes about a customer.

model VendorCustomer {
  id            String    @id @default(cuid())
  vendorId      String
  customerId    String
  vendor        Vendor    @relation(fields: [vendorId], references: [id])
  customer      Customer  @relation(fields: [customerId], references: [id])
  totalOrders   Int       @default(0)
  lastOrderAt   DateTime?
  reorderOptOut Boolean   @default(false) // per-vendor opt-out (v1 was global)
  notes         String?   // vendor notes about this customer

  @@unique([vendorId, customerId])
  @@map("vendor_customers")
}

// ─── v2: VendorSetupSession ───────────────────────────────────────────────────
// Tracks a vendor's onboarding progress through the LLM-powered setup flow.
// collectedData accumulates extracted answers as the conversation progresses.

model VendorSetupSession {
  id            String    @id @default(cuid())
  vendorId      String    @unique
  vendor        Vendor    @relation(fields: [vendorId], references: [id])
  step          String    @default("WELCOME") // WELCOME | COLLECTING_INFO | ADDING_PRODUCTS | PAYMENT_SETUP | CONFIRMATION | COMPLETE
  collectedData Json      @default("{}")       // partial answers accumulated by the LLM agent
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("vendor_setup_sessions")
}

// ─── v2: VendorNotificationNumber ────────────────────────────────────────────
// All WhatsApp numbers that receive order alerts for a vendor.
// One isPrimary=true record (the owner). Others are staff/branch numbers.

model VendorNotificationNumber {
  id        String   @id @default(cuid())
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id])
  phone     String
  label     String?  // e.g. "Garki Branch", "Main Manager"
  isActive  Boolean  @default(true)
  isPrimary Boolean  @default(false) // only the owner's number should be true

  createdAt DateTime @default(now())

  @@unique([vendorId, phone])
  @@map("vendor_notification_numbers")
}
