// WhatsApp Order Management Bot — Prisma Schema
//
// v1 (single-vendor): Physical, digital, hybrid goods. Kobo pricing. Working hours.
// v2 (multi-tenant):  Multiple vendors. VendorCustomer relations. Onboarding sessions.
//                     Notification numbers. Subscription tiers. Bot intelligence.
//
// Migration strategy: v1 fields kept intact for backward-compat. v2 fields added alongside.
// Phase 9 data migration will backfill ownerPhone/storeCode and clean up v1 fields.
//
// Rules:
//   - Monetary values stored in KOBO (integer). Display in ₦ at the app layer.
//   - Phone numbers in international format: +2348012345678

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Vendor ──────────────────────────────────────────────────────────────────

model Vendor {
  id             String     @id @default(uuid())
  businessName   String
  whatsappNumber String     @unique  // v1: primary identifier. v2 superseded by ownerPhone.
  phoneNumber    String
  vendorType     VendorType @default(PHYSICAL_GOODS)
  // API key stored as bcrypt hash — never plaintext
  apiKeyHash     String
  isActive       Boolean    @default(true)
  isVerified     Boolean    @default(false)

  // ── Working hours ────────────────────────────────────────────────────────
  workingHoursStart    String?  @default("08:00")
  workingHoursEnd      String?  @default("21:00")
  workingDays          String?  @default("1,2,3,4,5,6")
  timezone             String?  @default("Africa/Lagos")
  acceptOffHoursOrders Boolean  @default(false)

  // ── v2: Multi-tenant identity ─────────────────────────────────────────
  storeCode    String?  @unique   // short code for store deep-link: wa.me/PING?text=STORECODE
  ownerPhone   String?  @unique   // WhatsApp number used to manage the store (vendor side)
  ownerName    String?
  businessType String   @default("general") // food | fashion | beauty | digital | general
  description  String?            // shown on customer welcome screen
  welcomeMessage String?          // custom greeting override
  isPaused     Boolean  @default(false)     // vendor can pause/resume store
  mode         VendorMode @default(STORE)  // STORE = product catalogue, SUPPORT = service/booking

  // ── v2: Delivery options ─────────────────────────────────────────────
  // 'delivery' | 'pickup' | 'both' — controls checkout flow
  deliveryOptions    String   @default("delivery")

  // ── v2: Payment ───────────────────────────────────────────────────────
  paystackSecretKey  String?  // AES-256-GCM encrypted at rest
  bankName           String?
  bankAccountNumber  String?  // AES-256-GCM encrypted at rest
  bankAccountName    String?
  acceptedPayments   String   @default("both") // paystack | bank | both

  // ── v2: Bot intelligence ──────────────────────────────────────────────
  businessContext     String?  // free-text vendor feeds the bot ("we use halal meat only")
  faqs                String?  // JSON array: [{question, answer}]
  specialInstructions String?  // e.g. "No deliveries after 9pm"

  // ── v2: Subscription ─────────────────────────────────────────────────
  plan               String    @default("free") // free | starter | growth | pro
  subscriptionEndsAt DateTime?

  // ── WhatsApp Commerce (gated: WHATSAPP_COMMERCE_ENABLED) ─────────────
  // Populated once the vendor's catalogue is created in Meta Commerce Manager.
  whatsappCatalogueId String?

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // ── Relations ─────────────────────────────────────────────────────────
  products             Product[]
  orders               Order[]
  sessions             ConversationSession[]
  offHoursContacts     OffHoursContact[]
  // v2 relations:
  customers            VendorCustomer[]
  notificationNumbers  VendorNotificationNumber[]
  setupSession         VendorSetupSession?
  pickupLocations      PickupLocation[]
  supportKnowledge     SupportKnowledge[]
  serviceItems         ServiceItem[]
  bookings             Booking[]
  // Learning layer relations
  interactionLogs      InteractionLog[]
  uncertainInteractions UncertainInteraction[]
  orderIntelligence    OrderIntelligence[]
  // WhatsApp Commerce
  catalogueSyncLogs    CatalogueSyncLog[]

  @@map("vendors")
}

// ─── OffHoursContact ─────────────────────────────────────────────────────────
// Records each customer who messaged while the store was closed.
// Used by the opening-time notification job to send "we're open now!" messages.

model OffHoursContact {
  id            String   @id @default(uuid())
  vendorId      String
  customerPhone String
  contactedAt   DateTime @default(now())
  // Flipped to true once the opening notification has been sent
  notifiedOpen  Boolean  @default(false)

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, notifiedOpen])
  @@index([vendorId, contactedAt])
  @@map("off_hours_contacts")
}

// ─── Product ─────────────────────────────────────────────────────────────────
// Unified product model for both physical and digital items.
// Digital-only fields are nullable and ignored for physical products.

model Product {
  id          String      @id @default(uuid())
  vendorId    String
  name        String
  description String?
  // Price in kobo (e.g. ₦15,000 = 1500000)
  price       Int
  category    String      @default("General")
  productType ProductType @default(PHYSICAL)
  imageUrl    String?
  isAvailable Boolean     @default(true)
  sortOrder   Int         @default(0)  // v2: display order on menu

  // ── Physical product fields ──────────────────────────────────────────────
  // null = unlimited stock; 0 = out of stock
  stockCount  Int?

  // ── Digital product fields ───────────────────────────────────────────────
  // How the product is delivered: a URL link or a Cloudinary-hosted file
  deliveryType    DeliveryType? // LINK or FILE — null for physical products
  // The actual URL/link to send the customer (Cloudinary URL or external link)
  deliveryContent String?
  // Custom message sent to customer along with the link, e.g. "Welcome aboard!"
  deliveryMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor            Vendor            @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orderItems        OrderItem[]
  catalogueSyncLogs CatalogueSyncLog[]

  @@index([vendorId])
  @@index([vendorId, isAvailable])
  @@index([vendorId, productType])
  @@map("products")
}

// ─── CatalogueSyncLog ────────────────────────────────────────────────────────
// Tracks the WhatsApp Commerce sync state for each vendor product.
// Gated behind WHATSAPP_COMMERCE_ENABLED — records are only written when the
// feature is active. Do not activate until Meta Commerce approval lands.

model CatalogueSyncLog {
  id                String    @id @default(cuid())
  vendorId          String
  productId         String
  // The product ID assigned by Meta after a successful upload
  whatsappProductId String?
  // PENDING | SYNCED | FAILED
  syncStatus        String    @default("PENDING")
  lastSyncedAt      DateTime?
  errorMessage      String?
  createdAt         DateTime  @default(now())

  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([vendorId, productId])
  @@index([vendorId, syncStatus])
  @@map("catalogue_sync_logs")
}

// ─── Customer ────────────────────────────────────────────────────────────────

model Customer {
  id             String   @id @default(uuid())
  whatsappNumber String   @unique  // v1 identifier. v2 uses phone (same value, backfilled in Phase 9).
  name           String?
  language       String   @default("en")
  languageSet    Boolean  @default(false)
  reorderOptOut  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // v2: phone is the global identifier across all vendor stores
  phone String? @unique

  orders          Order[]
  sessions        ConversationSession[]
  vendorRelations VendorCustomer[]       // per-vendor relationship data

  @@map("customers")
}

// ─── Order ───────────────────────────────────────────────────────────────────
// orderType determines the status flow and delivery logic.
// deliveryAddress is only set for PHYSICAL orders.

model Order {
  id                String      @id @default(uuid())
  vendorId          String
  customerId        String
  orderType         OrderType   @default(PHYSICAL)
  status            OrderStatus @default(PENDING_PAYMENT)
  // Total amount in kobo
  totalAmount       Int
  // 'delivery' | 'pickup' — set at checkout
  deliveryType      String?
  // Home delivery orders only — null for pickup/digital
  deliveryAddress   String?
  // Pickup orders only — FK to vendor's PickupLocation
  pickupLocationId  String?
  notes             String?
  // Unique Paystack reference — used for idempotent webhook processing
  paystackReference String      @unique
  // Set to true after first successful payment webhook to prevent double-processing
  paymentProcessed  Boolean     @default(false)
  // For digital orders: track whether automatic delivery succeeded
  digitalDelivered  Boolean     @default(false)
  // Timestamp when order was physically delivered — used to schedule re-order nudges
  deliveredAt       DateTime?
  // Timestamp when a re-order nudge was sent — prevents duplicate nudges
  reorderSentAt     DateTime?
  // Payment method chosen at checkout: paystack_transfer | bank_transfer
  paymentMethod     String?
  // Dedicated virtual account assigned for Paystack Pay with Transfer
  virtualBankName      String?
  virtualAccountNumber String?
  virtualAccountExpiry DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  vendor         Vendor          @relation(fields: [vendorId], references: [id])
  customer       Customer        @relation(fields: [customerId], references: [id])
  orderItems     OrderItem[]
  pickupLocation PickupLocation? @relation(fields: [pickupLocationId], references: [id])

  @@index([vendorId])
  @@index([customerId])
  @@index([status])
  @@index([orderType])
  @@index([paystackReference])
  @@map("orders")
}

// ─── OrderItem ───────────────────────────────────────────────────────────────
// unitPrice snapshots the price at order time so historical amounts are stable.

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  // Price in kobo at the moment the order was placed
  unitPrice Int
  notes     String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ─── ConversationSession ─────────────────────────────────────────────────────
// Tracks each customer's position in the conversation state machine.
// One session per customer per vendor — upserted on each message.

model ConversationSession {
  id             String            @id @default(uuid())
  whatsappNumber String
  vendorId       String
  state          ConversationState @default(IDLE)
  // JSON blob: { cart, pendingProductId, deliveryAddress, activeOrderType, ... }
  sessionData    Json              @default("{}")
  expiresAt      DateTime
  updatedAt      DateTime          @updatedAt
  lastMessageId  String?

  // v2: customer FK by id (used by new router; no Prisma relation declared to avoid naming conflict)
  customerId     String?

  vendor   Vendor   @relation(fields: [vendorId], references: [id])
  customer Customer @relation(fields: [whatsappNumber], references: [whatsappNumber])

  // One active session per customer per vendor
  @@unique([whatsappNumber, vendorId])
  @@index([whatsappNumber])
  @@index([expiresAt])
  @@map("conversation_sessions")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum VendorType {
  PHYSICAL_GOODS
  DIGITAL_PRODUCTS
  HYBRID
}

enum ProductType {
  PHYSICAL
  DIGITAL
}

enum DeliveryType {
  LINK  // External URL or platform link (e.g. Google Drive, YouTube, Selar)
  FILE  // Cloudinary-hosted file URL
}

enum OrderType {
  PHYSICAL
  DIGITAL
}

enum VendorMode {
  STORE    // product catalogue + order flow (default)
  SUPPORT  // service business — FAQ + booking flow
}

enum OrderStatus {
  PENDING_PAYMENT   // v1: Order created, awaiting payment
  PAYMENT_PENDING   // v2: Virtual account / bank transfer created, waiting for payment
  PAYMENT_CONFIRMED // v1: Paystack confirmed payment
  PAID              // v2: Payment received and verified
  CONFIRMED         // Vendor confirmed the order (physical only)
  PREPARING         // Vendor is preparing the order (physical only)
  READY             // v1: Order ready for pickup/delivery
  OUT_FOR_DELIVERY  // v2: Order is on the way to the customer
  DELIVERED         // Physical order delivered
  DIGITAL_SENT      // Digital product delivered to customer
  CANCELLED         // Order cancelled (by vendor or system)
  EXPIRED           // v2: Payment window elapsed with no payment
  REJECTED          // v2: Vendor rejected a manual bank transfer claim
}

enum ConversationState {
  LANGUAGE_SELECTION // Brand-new customer choosing their preferred language
  IDLE               // No active conversation
  BROWSING           // Viewing catalog
  ORDERING           // Adding items to cart (physical) or viewing product detail (digital)
  AWAITING_ITEM_NOTE // Waiting for special instructions after item added to cart
  AWAITING_ADDRESS   // Waiting for delivery address (physical only)
  AWAITING_PAYMENT   // Payment link sent, waiting for Paystack webhook
  COMPLETED          // Order placed and confirmed — ready for fresh start
}

// ─── v2: VendorCustomer ───────────────────────────────────────────────────────
// Per-vendor relationship data for each customer. Tracks repeat orders,
// opt-outs, and vendor-specific notes about a customer.

model VendorCustomer {
  id            String    @id @default(cuid())
  vendorId      String
  customerId    String
  vendor        Vendor    @relation(fields: [vendorId], references: [id])
  customer      Customer  @relation(fields: [customerId], references: [id])
  totalOrders   Int       @default(0)
  lastOrderAt   DateTime?
  reorderOptOut Boolean   @default(false) // per-vendor opt-out (v1 was global)
  notes         String?   // vendor notes about this customer

  @@unique([vendorId, customerId])
  @@map("vendor_customers")
}

// ─── v2: VendorSetupSession ───────────────────────────────────────────────────
// Tracks a vendor's onboarding progress through the LLM-powered setup flow.
// collectedData accumulates extracted answers as the conversation progresses.

model VendorSetupSession {
  id            String    @id @default(cuid())
  vendorId      String    @unique
  vendor        Vendor    @relation(fields: [vendorId], references: [id])
  step          String    @default("WELCOME") // WELCOME | COLLECTING_INFO | ADDING_PRODUCTS | PAYMENT_SETUP | CONFIRMATION | COMPLETE
  collectedData Json      @default("{}")       // partial answers accumulated by the LLM agent
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("vendor_setup_sessions")
}

// ─── v2: PickupLocation ───────────────────────────────────────────────────────
// Vendor-configured physical collection points. Customers choose one at checkout
// when the vendor's deliveryOptions includes 'pickup'.

model PickupLocation {
  id         String   @id @default(uuid())
  vendorId   String
  vendor     Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name       String
  address    String
  landmark   String?
  city       String
  state      String
  hoursStart String?
  hoursEnd   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orders Order[]

  @@index([vendorId, isActive])
  @@map("pickup_locations")
}

// ─── v2: VendorNotificationNumber ────────────────────────────────────────────
// All WhatsApp numbers that receive order alerts for a vendor.
// One isPrimary=true record (the owner). Others are staff/branch numbers.

model VendorNotificationNumber {
  id        String   @id @default(cuid())
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id])
  phone     String
  label     String?  // e.g. "Garki Branch", "Main Manager"
  isActive  Boolean  @default(true)
  isPrimary Boolean  @default(false) // only the owner's number should be true

  createdAt DateTime @default(now())

  @@unique([vendorId, phone])
  @@map("vendor_notification_numbers")
}

// ─── Support Mode ─────────────────────────────────────────────────────────────
// Service-based businesses use Support Mode instead of the product catalogue flow.
// Customers can view services, ask questions (FAQ + LLM), and request bookings.

model SupportKnowledge {
  id        String   @id @default(uuid())
  vendorId  String
  question  String
  answer    String
  createdAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@map("support_knowledge")
}

model ServiceItem {
  id              String   @id @default(uuid())
  vendorId        String
  name            String
  price           Int      // in kobo
  unit            String   // "per session", "per kg", "per hour", etc.
  turnaroundHours Int?     // estimated completion time in hours
  description     String?
  isAvailable     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@map("service_items")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  READY
  COMPLETED
  CANCELLED
}

// ─── AI Learning Layer ────────────────────────────────────────────────────────
// Every interaction trains the bot. Nothing is hardcoded where learning is
// possible instead. Phone numbers are always stored masked; payment details
// are never stored here.

enum MessageType {
  TEXT
  VOICE
  IMAGE
  INTERACTIVE
}

model Booking {
  id               String        @id @default(uuid())
  vendorId         String
  customerPhone    String
  customerName     String?
  serviceRequested String
  scheduledDate    String?       // free-text date/time from customer (e.g. "Friday 10am")
  deliveryAddress  String?       // for pickup/mobile service vendors
  status           BookingStatus @default(PENDING)
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  vendor    Vendor            @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  reminders BookingReminder[]

  @@index([vendorId])
  @@index([vendorId, status])
  @@map("bookings")
}

// ─── BookingReminder ──────────────────────────────────────────────────────────
// Scheduled reminder entries for Support Mode appointment bookings.
// One booking can have at most one active (unsent) reminder at a time.
// Bull job ID is stored for cancellation when bookings are cancelled.

model BookingReminder {
  id              String   @id @default(cuid())
  bookingId       String
  customerId      String?                       // Customer.id — optional, for future analytics
  customerPhone   String
  serviceName     String
  businessName    String
  reminderTime    DateTime                      // when the Bull job fires
  appointmentTime DateTime                      // parsed appointment time — safety check in worker
  bullJobId       String?                       // Bull job ID for cancellation
  language        String   @default("en")       // customer language for the reminder message
  sent            Boolean  @default(false)

  createdAt       DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([sent, reminderTime])
  @@map("booking_reminders")
}

// ─── InteractionLog ───────────────────────────────────────────────────────────
// Ground-truth dataset: every incoming message with intent classification result.
// Raw phone numbers are NEVER stored here — always masked via maskPhone().

model InteractionLog {
  id                  String      @id @default(cuid())
  vendorId            String?
  customerPhoneMasked String                      // e.g. "+234****4020"
  sessionId           String?
  messageType         MessageType @default(TEXT)
  rawInput            String
  detectedLanguage    String?                     // en | pid | ig | yo | ha
  detectedIntent      String?                     // MENU | ORDER | UNKNOWN | …
  confidenceScore     Float?                      // 0.0–1.0 from LLM
  resolvedIntent      String?                     // what the bot actually did
  wasCorrect          Boolean?                    // null until confirmed by feedback
  flowState           String?                     // IDLE | BROWSING | ORDERING | …
  responseTimeMs      Int?
  createdAt           DateTime    @default(now())

  vendor Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([vendorId, createdAt])
  @@index([detectedLanguage, detectedIntent])
  @@index([confidenceScore])
  @@index([createdAt])
  @@map("interaction_logs")
}

// ─── LanguagePattern ─────────────────────────────────────────────────────────
// Growing library of real Nigerian expressions mapped to intents.
// Replaces hardcoded translations — single source of truth for language learning.

model LanguagePattern {
  id                String   @id @default(cuid())
  language          String                        // en | pid | ig | yo | ha
  intent            String                        // CustomerIntent name
  exampleInputs     String[]                      // real user inputs that triggered this intent
  preferredResponse String?                       // best response seen for this pattern
  useCount          Int      @default(1)
  lastSeenAt        DateTime @default(now())
  createdAt         DateTime @default(now())

  @@unique([language, intent])
  @@index([language])
  @@index([useCount])
  @@map("language_patterns")
}

// ─── UncertainInteraction ─────────────────────────────────────────────────────
// Inputs where the bot was unsure (confidence < 0.60).
// These are the priority training cases — the expressions the bot struggles most with.

model UncertainInteraction {
  id                  String   @id @default(cuid())
  vendorId            String?
  customerPhoneMasked String
  rawInput            String
  detectedLanguage    String?
  suggestedIntent     String?                     // what the LLM guessed
  confidenceScore     Float
  flowState           String?
  resolved            Boolean  @default(false)   // true once a human has reviewed it
  resolvedIntent      String?                     // correct intent after human review
  createdAt           DateTime @default(now())

  vendor Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([resolved, confidenceScore])
  @@index([createdAt])
  @@map("uncertain_interactions")
}

// ─── PidginLearningLog ────────────────────────────────────────────────────────
// Phrases in Nigerian Pidgin that the bot could not confidently classify.
// These are reviewed by humans and promoted to LanguagePattern or added to PIDGIN.md.
// Privacy: no raw phone numbers stored here.

model PidginLearningLog {
  id              String   @id @default(cuid())
  phrase          String                        // the raw Pidgin input
  inferredMeaning String?                       // best-guess intent or "UNKNOWN"
  context         String?                       // conversation state at time of message
  sessionId       String?                       // links back to ConversationSession if available
  status          String   @default("pending")  // pending | reviewed | added_to_pidgin_md
  createdAt       DateTime @default(now())

  @@index([status])
  @@index([createdAt])
  @@map("pidgin_learning_log")
}

// ─── OrderIntelligence ────────────────────────────────────────────────────────
// Basket analysis + ordering behaviour data. Powers product suggestions and
// drop-off detection. Never stores PII — vendor + order IDs only.

model OrderIntelligence {
  id           String   @id @default(cuid())
  vendorId     String
  orderId      String   @unique
  productIds   String[]                           // IDs of products in the order
  language     String?                            // language the customer used
  messageCount Int                                // messages taken to complete the order
  askedForHelp Boolean  @default(false)
  hourOfDay    Int                                // 0–23 (Lagos time)
  dayOfWeek    Int                                // 0=Sun … 6=Sat
  completedAt  DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([vendorId, hourOfDay])
  @@index([productIds])
  @@map("order_intelligence")
}
