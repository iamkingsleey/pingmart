# Server
NODE_ENV=development              # development | production | test
PORT=3000                         # HTTP port to listen on

# Database — PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pingmart

# Redis — For Bull queues and rate limiting
REDIS_URL=redis://localhost:6379

# WhatsApp — Meta Developer Console → Your App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=         # Phone number ID (not the actual phone number)
WHATSAPP_ACCESS_TOKEN=            # Permanent or temporary access token
WHATSAPP_BUSINESS_ACCOUNT_ID=     # WhatsApp Business Account ID
WHATSAPP_APP_SECRET=              # App Secret for webhook signature verification
WHATSAPP_WEBHOOK_VERIFY_TOKEN=    # Custom token you define for webhook verification

# Paystack — Dashboard → Settings → API Keys
PAYSTACK_SECRET_KEY=              # sk_live_... or sk_test_...
PAYSTACK_WEBHOOK_SECRET=          # Same as secret key (Paystack uses it for HMAC)

# Cloudinary — Dashboard → Product Environment Credentials
CLOUDINARY_CLOUD_NAME=            # Your cloud name
CLOUDINARY_API_KEY=               # API key
CLOUDINARY_API_SECRET=            # API secret

# Encryption — AES-256-GCM key for bank account numbers at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=                   # 64-character hex string (32 bytes)

# WhatsApp Commerce — Native image catalogue inside WhatsApp
# Set to true after Meta Commerce permissions are approved
# See FEATURES.md — WhatsApp Native Catalogue section for setup steps
WHATSAPP_COMMERCE_ENABLED=false
WHATSAPP_CATALOG_ID=              # From Meta Commerce Manager

# Admin / developer phone number (234XXXXXXXXXX format, no +)
# Used to gate developer-only test commands like TEST_OWO_PAY
ADMIN_PHONE_NUMBER=               # e.g. 2348012345678

# Mono OWO Payments — WhatsApp-native payment requests
# Set to true after Mono credentials are confirmed and tested
OWO_PAYMENTS_ENABLED=false
MONO_SECRET_KEY=                  # From Mono dashboard — NEVER log this value
MONO_PUBLIC_KEY=                  # From Mono dashboard
MONO_WEBHOOK_URL=                 # e.g. https://your-domain.com/webhooks/mono

# Vendor License Verification — restricted business categories (pharmacy, healthcare,
# alcohol, tobacco, financial_services) must upload a license document before going live.
# Prohibited categories (gambling, weapons, drugs, etc.) are blocked regardless of this flag.
VENDOR_LICENSE_VERIFICATION_ENABLED=false
